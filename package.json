{
  "name": "miyaru-profile-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:seed-db": "tsx prisma/seed-db.ts",
    "db:update": "prisma generate && prisma db push && tsx prisma/seed-db.ts",
    "update:all": "npm install && npm update && npm run db:update",
    "quality": "npm run lint && npm run type-check && npm run test && npm run build"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
